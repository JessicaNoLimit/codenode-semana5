---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

let proyectos = [];
let error = false;

try {
  const response = await fetch("http://localhost/wordpress/wp-json/wp/v2/portfolio");

  if (!response.ok) {
    throw new Error("No se pudieron cargar los proyectos");
  }

  proyectos = await response.json();
} catch (err) {
  console.error("Error al cargar proyectos desde WordPress:", err);
  error = true;
}
---

<BaseLayout title="Proyectos | Portfolio Jesica">
  <div class="inner-wall">
    <div class="inner-content proyectos-content">
      <h1>Proyectos</h1>
      <p class="subtitle">
        Una selección de proyectos reales.
      </p>

      {error ? (
        <p>No se pudieron cargar los proyectos desde WordPress en este momento.</p>
      ) : proyectos.length === 0 ? (
        <p>No hay proyectos disponibles.</p>
      ) : (
        proyectos.map((proyecto) => (
<ProjectCard
  titulo={proyecto.title.rendered}
  descripcion={proyecto.descripcion_corta || "Sin descripción"}
  slug={proyecto.slug}
  estado="Publicado"
  imagen={proyecto.imagen_proyecto || ""}
/>
        ))
      )}

      <div class="back-link">
        <a href="/">Volver al inicio</a>
      </div>
    </div>
  </div>
</BaseLayout>