---
import "../styles/global.css";

const proyectos = [
  {
    titulo: "Portfolio Astro",
    descripcion: "Portfolio personal creado con Astro, con varias páginas y navegación simple.",
  },
  {
    titulo: "Web WordPress",
    descripcion: "Página web desarrollada en WordPress con estructura personalizada y contenido dinámico.",
  },
  {
    titulo: "Formulario PHP",
    descripcion: "Formulario web con validación básica y recogida de datos utilizando PHP.",
  },
];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Proyectos | Portfolio Jesica</title>
  </head>
  <body>
    <main>
      <h1>Proyectos</h1>
      <p class="subtitle">Listado de proyectos de ejemplo renderizados dinámicamente</p>

      {proyectos.map((proyecto) => (
        <div class="card">
          <h2>{proyecto.titulo}</h2>
          <p>{proyecto.descripcion}</p>
        </div>
      ))}

      <div class="back-link">
        <a href="/">Volver al inicio</a>
      </div>
    </main>
  </body>
</html>