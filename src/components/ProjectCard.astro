---
const { titulo, descripcion, tecnologias, slug, enlace, estado } = Astro.props;
---

<div class="card">
  <h2>{titulo}</h2>
  <p>{descripcion}</p>

  <p>
    <strong>Tecnologías:</strong> {tecnologias.join(", ")}
  </p>

  <p>
    <strong>Estado:</strong> {estado}
  </p>

  {enlace ? (
    <a href={enlace} target="_blank" rel="noopener noreferrer">Ver proyecto</a>
  ) : (
    <p><strong>Próximamente</strong></p>
  )}
</div>