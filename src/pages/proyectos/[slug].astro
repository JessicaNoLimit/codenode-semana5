---
import "../../styles/global.css";
import { proyectos } from "../../data/proyectos.js";

export function getStaticPaths() {
  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.slug },
    props: { proyecto }
  }));
}

const { proyecto } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{proyecto.titulo} | Portfolio Jesica</title>
  </head>
  <body>
    <main>
      <h1>{proyecto.titulo}</h1>

      <p>{proyecto.descripcion}</p>

      <p>
        {proyecto.descripcionLarga}
      </p>

      <p><strong>Tecnologías:</strong> {proyecto.tecnologias.join(", ")}</p>

      <p><strong>Estado:</strong> {proyecto.estado}</p>

      {proyecto.enlace ? (
        <a href={proyecto.enlace} target="_blank">Ver proyecto</a>
      ) : (
        <p>Proyecto disponible próximamente</p>
      )}

      <div class="back-link">
        <a href="/proyectos">Volver a proyectos</a>
      </div>
    </main>
  </body>
</html>