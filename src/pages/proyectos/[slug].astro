---
import "../../styles/global.css";

export async function getStaticPaths() {
  const response = await fetch("http://localhost/wordpress/wp-json/wp/v2/portfolio");

  if (!response.ok) {
    throw new Error("No se pudieron cargar los proyectos de portfolio");
  }

  const proyectos = await response.json();

  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.slug },
    props: { proyecto }
  }));
}

const { proyecto } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{proyecto.title.rendered} | Portfolio Jesica</title>
  </head>
  <body>
    <main>
      {proyecto.imagen_proyecto && (
        <img src={proyecto.imagen_proyecto} alt={proyecto.title.rendered} class="project-image" />
      )}

      <h1>{proyecto.title.rendered}</h1>

      <p>{proyecto.descripcion_corta || "Sin descripción disponible."}</p>

      <p><strong>Estado:</strong> Publicado</p>

      {proyecto.url_proyecto ? (
        <a href={proyecto.url_proyecto} target="_blank" rel="noopener noreferrer">Ver proyecto</a>
      ) : (
        <p>Proyecto disponible próximamente</p>
      )}

      <div class="back-link">
        <a href="/proyectos">Volver a proyectos</a>
      </div>
    </main>
  </body>
</html>