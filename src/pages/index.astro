---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Inicio | Portfolio Jesica">
  <section class="scene-wall">
<div class="name-frame">
  <p class="frame-label">Portfolio</p>
  <h1>Jesica Serrano</h1>
</div>
    </div>

    <div class="mirror-wrap">
      <div class="mirror-glow"></div>
      <img src="/Jesica.png" alt="Jesica Serrano" class="mirror-photo" />
    </div>

    <div class="intro-card">
      <p class="intro-role">Desarrolladora web en formación</p>
      <p>
        Estoy construyendo mi camino en desarrollo web creando proyectos con
        estructura real, diseño cuidado y una identidad visual propia.
      </p>

      <div class="scene-links">
       <a href="/sobre-mi" class="btn-primary">Sobre mí</a>
<a href="/proyectos">Proyectos</a>
      </div>
    </div>
  </section>
</BaseLayout>